# Unified model endpoint.
#
# llms.py builds every client with langchain_openai.ChatOpenAI, i.e. any
# OpenAI-compatible endpoint works here — not just OpenAI itself. For a
# low-cost setup, DeepSeek's API is OpenAI-compatible and inexpensive:
#
#   MODEL_NAME=deepseek-chat
#   MODEL_API_KEY=<your DeepSeek API key from platform.deepseek.com>
#   MODEL_BASE_URL=https://api.deepseek.com
#
# (deepseek-chat = DeepSeek-V3, general purpose; deepseek-reasoner = R1, for
# steps that benefit from more deliberate reasoning — e.g. QUALITY_MODEL_NAME
# below, if deepseek-chat alone isn't reliable enough at generating/repairing
# machine code.)
MODEL_NAME=
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TEMPERATURE=0
MODEL_MAX_TOKENS=8000

# Optional role aliases (default to MODEL_NAME). Cheapest working setup: leave
# all of these blank and let everything share MODEL_NAME. If generation/
# validation-repair quality is the bottleneck, only raise QUALITY_MODEL_NAME
# (used by generate_machine_code / align_draft_to_automation) — FAST_MODEL_NAME
# (routing/classification) rarely needs a stronger model.
FAST_MODEL_NAME=
GENERAL_MODEL_NAME=
QUALITY_MODEL_NAME=
LONG_CONTEXT_MODEL_NAME=

# Optional retrieval embedding endpoint (public example only)
EMBEDDING_MODEL_NAME=
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# Optional Mem0 model
MEMORY_MODEL_NAME=

# ---------------------------------------------------------------------------
# labclaude + OT-2 Deck Studio target (src/capabilities/targets/labclaude_ot2.py)
# Set LABCLAUDE_OT2_TARGET=1 to make generate_machine_code/validate_machine_code
# emit and verify {ot2_protocol, labclaude_workflow} instead of the generic
# nodes/consumables/connections schema. See run_labclaude_agent.py.
# ---------------------------------------------------------------------------
LABCLAUDE_OT2_TARGET=
LABCLAUDE_BASE_URL=http://127.0.0.1:8000
LABCLAUDE_TOKEN=
OT2_BASE_URL=http://127.0.0.1:4180
OT2_TOKEN=
OT2_RUN_TIMEOUT_S=120
