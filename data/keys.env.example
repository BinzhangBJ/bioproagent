# Unified model endpoint.
#
# llms.py builds every client with langchain_openai.ChatOpenAI, i.e. any
# OpenAI-compatible endpoint works here — not just OpenAI itself. For a
# low-cost setup, DeepSeek's API is OpenAI-compatible and inexpensive:
#
#   MODEL_NAME=deepseek-chat
#   MODEL_API_KEY=<your DeepSeek API key from platform.deepseek.com>
#   MODEL_BASE_URL=https://api.deepseek.com
#
# (deepseek-chat = DeepSeek-V3, general purpose; deepseek-reasoner = R1, for
# steps that benefit from more deliberate reasoning — e.g. QUALITY_MODEL_NAME
# below, if deepseek-chat alone isn't reliable enough at generating/repairing
# machine code.)
MODEL_NAME=
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TEMPERATURE=0
MODEL_MAX_TOKENS=8000

# Optional role aliases (default to MODEL_NAME). Cheapest working setup: leave
# all of these blank and let everything share MODEL_NAME. If generation/
# validation-repair quality is the bottleneck, only raise QUALITY_MODEL_NAME
# (used by generate_machine_code / align_draft_to_automation) — FAST_MODEL_NAME
# (routing/classification) rarely needs a stronger model.
FAST_MODEL_NAME=
GENERAL_MODEL_NAME=
QUALITY_MODEL_NAME=
LONG_CONTEXT_MODEL_NAME=

# Optional retrieval embedding endpoint (public example only)
EMBEDDING_MODEL_NAME=
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# Optional Mem0 model
MEMORY_MODEL_NAME=

# ---------------------------------------------------------------------------
# labclaude + OT-2 Deck Studio target (src/capabilities/targets/labclaude_ot2.py)
# Set LABCLAUDE_OT2_TARGET=1 to make generate_machine_code/validate_machine_code
# emit and verify {ot2_protocol, labclaude_workflow} instead of the generic
# nodes/consumables/connections schema. See run_labclaude_agent.py.
# ---------------------------------------------------------------------------
LABCLAUDE_OT2_TARGET=
LABCLAUDE_BASE_URL=http://127.0.0.1:8000
# labclaude ships a dedicated "bioproagent" account (role 自动化Agent, VIEW +
# CONFIG_WORKFLOW only — no RUN_TASK/CONTROL_DEVICE) precisely so workflows
# this agent commits are attributable in the audit trail, distinct from a
# human's UI-built ones (workflows.source == 'agent' vs 'human', derived
# server-side from the login, not from anything this script sends). Get the
# token via: curl -X POST $LABCLAUDE_BASE_URL/api/login -d '{"username":"bioproagent"}'
# -H 'Content-Type: application/json'. Do NOT reuse engineer/admin here.
LABCLAUDE_TOKEN=
OT2_BASE_URL=http://127.0.0.1:4180
OT2_TOKEN=
OT2_RUN_TIMEOUT_S=120

# ---------------------------------------------------------------------------
# BayesOpt Agent target (src/capabilities/targets/bayesopt.py)
# Set BAYESOPT_TARGET=1 to enable run_labclaude_agent.py's --bayesopt-study
# flag: fetch a suggested experiment/protocol parameter set (temperature,
# cycles, buffer, ...) from a running bayesopt-agent service before the FSM
# runs, and later report the real measured outcome back with
# --bayesopt-observe-params/--bayesopt-observe-objective. This optimizes
# experiment parameters, NOT scheduler/device runtime parameters — unrelated
# to labclaude's own scheduling optimizations.
# ---------------------------------------------------------------------------
BAYESOPT_TARGET=
BAYESOPT_BASE_URL=http://127.0.0.1:8100
# Mint with: python scripts/create_token.py "bioproagent" (run inside the
# bayesopt-agent repo) — that service has no user/login system, just Bearer
# tokens, since it's a stateless advisor, not a system of record.
BAYESOPT_TOKEN=
